{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Village",
  "version": "0.1.0",
  "identifier": "com.village.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Village",
        "width": 480,
        "height": 640,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../bin/edge.exe": "edge.exe",
      "../bin/tap-driver/devcon.exe": "tap-driver/devcon.exe",
      "../bin/tap-driver/OemVista.inf": "tap-driver/OemVista.inf",
      "../bin/tap-driver/tap0901.cat": "tap-driver/tap0901.cat",
      "../bin/tap-driver/tap0901.sys": "tap-driver/tap0901.sys",
      "../target/release/village-service.exe": "village-service.exe"
    }
  }
}
